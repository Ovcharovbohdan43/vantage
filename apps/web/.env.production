# Public production API (Railway). Required so SSR library pages and rewrites
# do not fall back to localhost and render an empty Research Library.
NEXT_PUBLIC_API_URL=https://vantage-production-83be.up.railway.app
API_INTERNAL_URL=https://vantage-production-83be.up.railway.app
# Browser calls go same-origin via Next rewrites (avoids Railway CORS gaps).
NEXT_PUBLIC_API_PROXY=1
