# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Add these Redirect URLs in Supabase Dashboard → Authentication → URL Configuration:
# Site URL must be your app origin (NOT only "/"):
#   http://localhost:3000   (or :3001 if that’s your local port)
#   https://your-production-domain
#
# Redirect allow-list:
# http://localhost:3000/auth/callback
# http://localhost:3000/auth/callback?flow=confirm
# http://localhost:3000/auth/callback?flow=recovery
# http://localhost:3001/auth/callback
# https://your-production-domain/auth/callback
# https://your-production-domain/auth/callback?flow=confirm
# https://your-production-domain/auth/callback?flow=recovery
#
# Paste updated templates from infra/email/templates (token_hash links → /auth/callback)
# Authentication → SMTP → Resend as documented in infra/email/README.md

# Backend API — only needed for production or running web without `npm run dev` from repo root.
# Local dev uses Next.js proxy (/api/v1 → API) — see scripts/run-dev.mjs
# NEXT_PUBLIC_API_URL=http://localhost:8000
#
# Production (Vercel): set both so SSR and rewrites reach Railway (see .env.production).
# NEXT_PUBLIC_API_URL=https://your-api.up.railway.app
# API_INTERNAL_URL=https://your-api.up.railway.app

# Canonical site URL (no trailing slash) — used by sitemap, robots, OG, JSON-LD.
# NEXT_PUBLIC_SITE_URL=https://vantageserch.app
