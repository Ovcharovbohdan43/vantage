# App
DEBUG=false
CORS_ORIGINS=http://localhost:3000

# Database (Supabase Postgres connection string)
DATABASE_URL=postgresql+asyncpg://postgres:password@db.your-project.supabase.co:5432/postgres

# Supabase Auth (JWT secret from Project Settings → API → JWT Secret)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — all app emails (send + inbound webhook)
# Webhook URL: POST {API_URL}/api/v1/email/webhook  (event: email.received)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=Vantage <noreply@vantageserch.app>
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxx
RESEND_REPLY_TO=
# Public web URL — used for Stripe redirects, List-Unsubscribe, and email footers.
# In production set this to https://vantageserch.app (localhost is auto-replaced when DEBUG=false).
APP_WEB_URL=https://vantageserch.app
# Server-only — where Support form emails go (never sent to the frontend)
SUPPORT_INBOX_EMAIL=f62688798@gmail.com
# Resend Receiving domain for support+{user_id}@… replies (enable MX on this domain)
SUPPORT_REPLY_DOMAIN=vantageserch.app

# Supabase Auth SMTP (Dashboard → Project Settings → Authentication → SMTP)
# Provider: custom | Host: smtp.resend.com | Port: 587 | User: resend
# Password: your RESEND_API_KEY | Sender: same as RESEND_FROM_EMAIL
# Also paste infra/email/templates/reset-password.html into Auth → Email → Reset password
# Redirect URLs: {APP_WEB_URL}/auth/callback?flow=confirm and ?flow=recovery

# Monitoring
SENTRY_DSN=

# Celery (optional — defaults to in-memory broker for local dev)
REDIS_URL=
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# Idea of the Week — Google Trends via SerpApi + Monday cron authentication
SERPAPI_API_KEY=
SERPAPI_TIMEOUT_SECONDS=20
SERPAPI_MONTHLY_BUDGET=250
IDEA_OF_WEEK_CRON_SECRET=

# Paid social-share draft generation
SHARE_DRAFT_PRICE_CENTS=50
SHARE_DRAFT_FREE_USER_IDS=db1c0e15-f6f4-4b59-b6b9-b2d56cb508b8
SHARE_DRAFT_FREE_EMAILS=f62688798@gmail.com
