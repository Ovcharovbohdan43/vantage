# Copy to apps/api/.env and fill in values from Supabase Dashboard

DEBUG=false
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Database → Supabase → Database → Connection string (Transaction pooler, port 6543)
# Paste the URI here and use postgresql+asyncpg:// (postgresql:// is auto-converted)
DATABASE_URL=postgresql+asyncpg://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Supabase → Project Settings → API (https://xxx.supabase.co — NOT the database URI)
SUPABASE_URL=https://ifltxtbgbjbpkucmlegy.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-dashboard

# OpenAI — competitor discovery (Phase 2) + embeddings (Phase 4)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional
REDIS_URL=
SENTRY_DSN=

# Stripe — one-time credit packs (Dashboard → Products → Prices)
# Or run: py scripts/provision_stripe.py (after setting STRIPE_SECRET_KEY)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...   # $9 — 1 credit
STRIPE_PRICE_FOUNDER=price_...   # $29 — 5 credits
STRIPE_PRICE_INDIE=price_...     # $79 — 20 credits
APP_WEB_URL=http://localhost:3000

# Preview review cap per competitor (default: 5 prod, 100 when DEBUG=true)
# PREVIEW_MAX_REVIEWS_PER_COMPETITOR=100

# Scraping: Crawlee collector is primary; Apify is automatic fallback when a
# competitor returns 0 reviews (optional but recommended in production).
SCRAPER_PROVIDER=crawlee
REVIEW_COLLECTOR_URL=http://localhost:8080
REVIEW_COLLECTOR_API_KEY=change-me
REVIEW_COLLECTOR_TIMEOUT_SECONDS=600

# Optional Apify fallback
# APIFY_TOKEN=
# APIFY_REVIEWS_ACTOR=zen-studio/software-review-scraper
# APIFY_TIMEOUT_SECONDS=600
