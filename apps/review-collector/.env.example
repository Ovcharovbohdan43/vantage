PORT=8080
# Shared with main API (Supabase Postgres). Prefer direct connection for long scrapes.
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Protects HTTP endpoints between Railway services
COLLECTOR_API_KEY=change-me

# Preferred: Webshare API key — collector loads username/password at startup
# Dashboard → API → create token
WEBSHARE_API_KEY=

# Optional overrides (used only when WEBSHARE_API_KEY is empty)
WEBSHARE_PROXY_HOST=p.webshare.io
WEBSHARE_PROXY_PORT=80
WEBSHARE_PROXY_PORTS=80,1080,3128
WEBSHARE_COUNTRY=US

# Crawl tuning — soft defaults (low RPM, long pauses, sequential pages)
MAX_NEGATIVE_RATING=3
REQUEST_DELAY_MS=6000
DELAY_JITTER_MS=4000
MAX_REQUESTS_PER_MINUTE=4
MAX_PAGES_PER_PRODUCT=3
PAGE_TIMEOUT_MS=60000
MIN_REVIEW_LENGTH=50
CACHE_TTL_HOURS=168
# COLLECTOR_HEADLESS=0  # headful can trigger G2 "inspection tools" heuristics
