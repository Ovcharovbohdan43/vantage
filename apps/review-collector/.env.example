PORT=8080
# Shared with main API (Supabase Postgres). Prefer direct connection for long scrapes.
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Protects HTTP endpoints between Railway services
COLLECTOR_API_KEY=change-me

# Webshare rotating residential — Username/Password (recommended on Railway)
# Dashboard → Proxy → Authentication → Username / Password
WEBSHARE_PROXY_HOST=p.webshare.io
WEBSHARE_PROXY_PORT=80
WEBSHARE_PROXY_USERNAME=
WEBSHARE_PROXY_PASSWORD=

# Or a full URL (overrides host/user/pass). For Authorized IP only: http://p.webshare.io:80
# WEBSHARE_PROXY_URL=http://user:pass@p.webshare.io:80

# Crawl tuning
MAX_NEGATIVE_RATING=3
REQUEST_DELAY_MS=1500
PAGE_TIMEOUT_MS=60000
MIN_REVIEW_LENGTH=50
CACHE_TTL_HOURS=168
